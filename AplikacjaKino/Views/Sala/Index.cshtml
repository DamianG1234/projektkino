@model IEnumerable<AplikacjaKino.Models.Sala>
@{
    ViewData["Title"] = "Zarządzanie salami";
}
<div class="container mt-4">
    <h2 class="mb-4">Sale kinowe</h2>
    <a href="@Url.Action("Create","Sala")" class="btn btn-primary mb-3">+ Dodaj salę</a>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nazwa</th>
                <th>Liczba rzędów</th>
                <th>Miejsc w rzędzie</th>
                <th>Łącznie miejsc</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sala in Model)
            {
                    <tr>
                        <td>@sala.Nazwa</td>
                        <td>@sala.LiczbaRzedow</td>
                        <td>@sala.MiejscWRzedzie</td>
                        <td>@(sala.LiczbaRzedow * sala.MiejscWRzedzie)</td>
                        <td>
                            <a href="@Url.Action("Edit","Sala", new { id = sala.Id })" class="btn btn-sm btn-warning">Edytuj</a>
                            <a href="@Url.Action("Delete","Sala", new { id = sala.Id })" class="btn btn-sm btn-danger">Usuń</a>
                        </td>
                    </tr>
            }
        </tbody>
    </table>
</div>