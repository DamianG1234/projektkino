@model AplikacjaKino.Models.Seans
@{
    ViewData["Title"] = "Rezerwacje dla seansu";
    var userEmails = ViewBag.UserEmails as Dictionary<string, string>;
}
<div class="container mt-4">
    <h2 class="mb-2">Rezerwacje — @Model.Film.Tytul</h2>
    <p class="text-muted">@Model.DataGodzina.ToString("dd.MM.yyyy HH:mm") | Sala: @Model.Sala.Nazwa</p>
    @if (!Model.Rezerwacje.Any())
    {
            <div class="alert alert-info">Brak rezerwacji dla tego seansu.</div>
    }
    else
    {
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>E-mail</th>
                        <th>Rząd</th>
                        <th>Miejsce</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Rezerwacje)
                {
                            <tr>
                                <td>
                            @{
                                string email = "-";
                                if (r.UserId != null && userEmails != null && userEmails.ContainsKey(r.UserId))
                                {
                                    email = userEmails[r.UserId];
                                }
                            }
                            @email
                                </td>
                                <td>@r.NumerRzedu</td>
                                <td>@r.NumerMiejsca</td>
                                <td>
                                    <form asp-action="UsunRezerwacje" method="post">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <input type="hidden" name="seansId" value="@Model.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                                    </form>
                                </td>
                            </tr>
                }
                </tbody>
            </table>
    }
    <a href="@Url.Action("Manage","Seans")" class="btn btn-secondary mt-2">Wróć</a>
</div>