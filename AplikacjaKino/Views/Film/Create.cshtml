@model AplikacjaKino.Models.Film
@{
    ViewData["Title"] = "Dodaj film";
}
<div class="container mt-4">
    <h2 class="mb-4">Dodaj film</h2>
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label asp-for="Tytul" class="form-label">Tytuł</label>
                    <input asp-for="Tytul" class="form-control" />
                    <span asp-validation-for="Tytul" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Opis" class="form-label">Opis</label>
                    <textarea asp-for="Opis" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Opis" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CzasTrwaniaMin" class="form-label">Czas trwania (min)</label>
                    <input asp-for="CzasTrwaniaMin" class="form-control" type="number" />
                    <span asp-validation-for="CzasTrwaniaMin" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Okładka</label>
                    <input type="file" name="okladka" class="form-control" accept="image/*" />
                </div>
                <button type="submit" class="btn btn-primary">Zapisz</button>
                <a href="@Url.Action("Index","Film")" class="btn btn-secondary">Anuluj</a>
            </form>
        </div>
    </div>
</div>