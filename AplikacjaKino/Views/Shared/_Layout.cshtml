<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AplikacjaKino</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand fw-bold" href="@Url.Action("Index","Home")">🎬 AplikacjaKino</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index","Seans")">Repertuar</a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Panel admina</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="@Url.Action("Index","Film")">Filmy</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("Index","Sala")">Sale</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("Manage","Seans")">Seanse</a></li>
                                </ul>
                            </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (!User.IsInRole("Admin"))
                        {
                                    <li class="nav-item">
                                        <a class="nav-link" href="@Url.Action("MojeRezerwacje","Seans")">Moje rezerwacje</a>
                                    </li>
                        }
                            <li class="nav-item">
                                <span class="nav-link text-light">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                    <button type="submit" class="btn btn-outline-light btn-sm mt-2">Wyloguj</button>
                                </form>
                            </li>
                    }
                    else
                    {
                            <li class="nav-item">
                                <a class="nav-link" href="/Identity/Account/Login">Zaloguj się</a>
                            </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <main class="pb-5 flex-grow-1 container pt-4">
        @RenderBody()
    </main>
    <footer class="bg-dark text-white text-center py-3 mt-5">
        <p class="mb-0">&copy; @DateTime.Now.Year AplikacjaKino</p>
    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>